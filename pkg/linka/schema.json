{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"title": "Linka Config 2.0",
	"type": "object",
	"required": ["metadata", "settings", "blocks"],
	"additionalProperties": false,
	"properties": {
		"metadata": {
			"type": "object",
			"required": ["version"],
			"additionalProperties": false,
			"properties": {
				"version": { "type": "string" },
				"title": { "type": "string" }
			}
		},
		"settings": {
			"type": "object",
			"required": ["columns", "rows"],
			"additionalProperties": false,
			"properties": {
				"columns": { "type": "integer", "minimum": 1, "maximum": 100 },
				"rows": { "type": "integer", "minimum": 1, "maximum": 100 }
			}
		},
		"blocks": {
			"type": "array",
			"minItems": 1,
			"items": {
				"type": "object",
				"required": ["id", "type", "elements"],
				"additionalProperties": false,
				"properties": {
					"id": { "type": "string", "minLength": 1 },
					"type": {
						"type": "string",
						"enum": [
							"grid",
							"single_choice",
							"multi_choice",
							"matching",
							"categories",
							"sequence"
						]
					},
					"elements": {
						"type": "array",
						"minItems": 1,
						"items": {
							"type": "object",
							"required": ["id", "kind"],
							"additionalProperties": false,
							"properties": {
								"id": { "type": "string", "minLength": 1 },
								"kind": {
									"type": "string",
									"enum": ["text", "image", "audio"]
								},
								"value": { "type": "string" },
								"media_url": { "type": "string", "format": "uri-reference" }
							}
						}
					},
					"answers": {
						"type": "array",
						"items": {
							"type": "object",
							"additionalProperties": false,
							"properties": {
								"element_id": { "type": "string" },
								"is_correct": { "type": "boolean" }
							}
						}
					},
					"sequence": {
						"type": "array",
						"items": {
							"type": "object",
							"additionalProperties": false,
							"properties": {
								"element_id": { "type": "string" },
								"order": { "type": "integer" }
							}
						}
					},
					"pairs": {
						"type": "array",
						"items": {
							"type": "object",
							"additionalProperties": false,
							"properties": {
								"left_id": { "type": "string" },
								"right_id": { "type": "string" }
							}
						}
					},
					"categories": {
						"type": "array",
						"items": {
							"type": "object",
							"additionalProperties": false,
							"properties": {
								"id": { "type": "string" },
								"name": { "type": "string" },
								"items": {
									"type": "array",
									"items": { "type": "string" }
								}
							}
						}
					}
				}
			}
		}
	}
}
